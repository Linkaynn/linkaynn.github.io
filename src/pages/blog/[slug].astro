---
import Layout from "../../layouts/Layout.astro";
import { getCollection, getEntry } from "astro:content";

export async function getStaticPaths() {
  const all = await getCollection("blog");
  const showDrafts = import.meta.env.DEV;
  const drafts = new Set<string>();
  if (!showDrafts) {
    for (const e of all) {
      if (e.data.draft) drafts.add(e.id.replace(/\.(md|mdx)$/, "").split("/")[0]);
    }
  }
  const slugs = new Set(
    all.map((e) => e.id.replace(/\.(md|mdx)$/, "").split("/")[0])
  );
  return [...slugs]
    .filter((s) => !drafts.has(s))
    .map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

const es = await getEntry("blog", `${slug}/es`);
const en = await getEntry("blog", `${slug}/en`);
if (!es || !en) {
  throw new Error(`Missing es/en markdown for blog slug "${slug}"`);
}

const { Content: ContentEs } = await es.render();
const { Content: ContentEn } = await en.render();

const fmtDate = (d: Date) =>
  d
    .toLocaleDateString("en-GB", { day: "2-digit", month: "2-digit", year: "numeric" })
    .replace(/\//g, " · ");
---

<Layout
  title={`${en.data.title} | ${es.data.title}`}
  description={en.data.excerpt}
  keywords={(en.data.tags ?? []).join(", ")}
  image="/blog.png"
>
  <article class="post">
    <!-- ───────── Spanish ───────── -->
    <div data-lang="es">
      <header class="post-head reveal" data-blur="0" data-y="6">
        <a href="/" class="back-link">← <span class="scramble" data-text="volver">volver</span></a>
        <h1>{es.data.title}</h1>
        <div class="post-meta">
          <time datetime={es.data.date.toISOString()}>{fmtDate(es.data.date)}</time>
          <span class="dotsep">·</span>
          <span>{es.data.readtime}</span>
        </div>
      </header>
      <div class="post-body">
        <ContentEs />
      </div>
    </div>

    <!-- ───────── English ───────── -->
    <div data-lang="en" hidden>
      <header class="post-head reveal" data-blur="0" data-y="6">
        <a href="/" class="back-link">← <span class="scramble" data-text="back">back</span></a>
        <h1>{en.data.title}</h1>
        <div class="post-meta">
          <time datetime={en.data.date.toISOString()}>{fmtDate(en.data.date)}</time>
          <span class="dotsep">·</span>
          <span>{en.data.readtime}</span>
        </div>
      </header>
      <div class="post-body">
        <ContentEn />
      </div>
    </div>
  </article>

  <!-- ───────── Image lightbox ───────── -->
  <div id="lightbox" class="lightbox" hidden aria-hidden="true" role="dialog">
    <button type="button" class="lightbox-close" aria-label="Close">×</button>
    <img class="lightbox-img" alt="" />
    <figcaption class="lightbox-cap" hidden></figcaption>
  </div>
</Layout>

<script>
  const lb = document.getElementById("lightbox") as HTMLElement | null;
  const lbImg = lb?.querySelector(".lightbox-img") as HTMLImageElement | null;
  const lbCap = lb?.querySelector(".lightbox-cap") as HTMLElement | null;
  const closeBtn = lb?.querySelector(".lightbox-close") as HTMLButtonElement | null;

  if (lb && lbImg && lbCap && closeBtn) {
    // Escape any ancestor stacking context (e.g. <main> with z-index)
    // so the overlay always sits above the site header/footer.
    if (lb.parentElement !== document.body) {
      document.body.appendChild(lb);
    }

    const open = (src: string, alt: string, caption: string | null) => {
      lbImg.src = src;
      lbImg.alt = alt;
      if (caption) {
        lbCap.textContent = caption;
        lbCap.hidden = false;
      } else {
        lbCap.hidden = true;
      }
      lb.hidden = false;
      lb.setAttribute("aria-hidden", "false");
      // next frame so CSS transition kicks in
      requestAnimationFrame(() => lb.classList.add("open"));
      document.body.style.overflow = "hidden";
    };
    const close = () => {
      lb.classList.remove("open");
      lb.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      // wait for fade-out before hiding so transition plays
      setTimeout(() => { lb.hidden = true; lbImg.src = ""; }, 200);
    };

    document.querySelectorAll<HTMLImageElement>(".post-body img").forEach((img) => {
      img.classList.add("zoomable");
      img.addEventListener("click", () => {
        const fig = img.closest("figure");
        const cap = fig?.querySelector("figcaption")?.textContent?.trim() ?? null;
        open(img.currentSrc || img.src, img.alt, cap);
      });
    });

    lb.addEventListener("click", (e) => {
      if (e.target === lb || e.target === closeBtn) close();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !lb.hidden) close();
    });
  }
</script>

<style is:global>
  /* ─── Post layout (mirrors the home column) ─── */
  .post {
    max-width: 640px;
    margin: 0 auto;
    padding-bottom: 80px;
    color: var(--ink-2);
    font-family: var(--font-mono);
    font-size: 15px;
    line-height: 1.75;
  }
  .post-head {
    margin-bottom: 36px;
  }
  .post-head .back-link {
    display: inline-block;
    color: var(--muted);
    font-size: 13px;
    margin-bottom: 28px;
    transition: color .2s var(--ease-out);
  }
  .post-head .back-link:hover { color: var(--accent); }
  .post h1 {
    font-family: var(--font-mono);
    font-size: 28px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.02em;
    line-height: 1.25;
    margin: 0 0 12px;
  }
  .post-meta {
    display: flex;
    gap: 10px;
    align-items: center;
    color: var(--muted-2);
    font-size: 12px;
  }
  .post .dotsep { color: var(--muted-2); }

  /* ─── Markdown body styling ─── */
  .post-body p {
    margin: 0 0 18px;
    color: var(--ink-2);
  }
  .post-body strong { color: var(--ink); font-weight: 600; }
  .post-body em     { color: var(--ink); font-style: italic; }
  .post-body a {
    color: var(--accent);
    border-bottom: 1px solid color-mix(in oklab, var(--accent) 50%, transparent);
    transition: border-color .2s var(--ease-out);
  }
  .post-body a:hover { border-bottom-color: var(--accent); }

  .post-body h2,
  .post-body h3,
  .post-body h4 {
    font-family: var(--font-mono);
    color: var(--ink);
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 36px 0 12px;
  }
  .post-body h2 { font-size: 20px; }
  .post-body h3 { font-size: 17px; }
  .post-body h4 { font-size: 15px; }

  .post-body ul,
  .post-body ol {
    margin: 0 0 18px 24px;
  }
  .post-body li { margin: 4px 0; }

  .post-body blockquote {
    margin: 28px 0;
    padding: 16px 18px;
    border-left: 2px solid var(--accent);
    background: var(--bg-elev);
    color: var(--ink-2);
    font-style: normal;
  }
  .post-body blockquote p { margin: 6px 0; }
  .post-body blockquote .speaker {
    color: var(--accent);
    font-weight: 600;
    margin-right: 4px;
  }

  /* Inline code and fenced code blocks */
  .post-body :not(pre) > code {
    font-family: var(--font-mono);
    background: var(--bg-elev);
    border: 1px solid var(--line);
    padding: 1px 5px;
    font-size: 0.92em;
    color: var(--ink);
  }
  .post-body pre {
    margin: 28px 0;
    padding: 16px 18px;
    border: 1px solid var(--line);
    border-left: 2px solid var(--accent);
    overflow-x: auto;
    font-size: 13px;
    line-height: 1.55;
    background: var(--paper) !important; /* override shiki bg, keep tokens */
  }
  .post-body pre code {
    font-family: var(--font-mono);
    background: transparent;
    border: none;
    padding: 0;
  }
  /* Switch shiki tokens via our data-theme rather than prefers-color-scheme */
  html[data-theme="dark"] .post-body .astro-code,
  html[data-theme="dark"] .post-body .astro-code span {
    color: var(--shiki-dark) !important;
    background-color: transparent !important;
    font-style: var(--shiki-dark-font-style) !important;
    font-weight: var(--shiki-dark-font-weight) !important;
    text-decoration: var(--shiki-dark-text-decoration) !important;
  }
  html[data-theme="light"] .post-body .astro-code,
  html[data-theme="light"] .post-body .astro-code span {
    color: var(--shiki-light) !important;
    background-color: transparent !important;
    font-style: var(--shiki-light-font-style) !important;
    font-weight: var(--shiki-light-font-weight) !important;
    text-decoration: var(--shiki-light-text-decoration) !important;
  }

  .post-body figure {
    margin: 32px 0;
    text-align: center;
  }
  .post-body figure img {
    max-width: 100%;
    height: auto;
    border: 1px solid var(--line);
    background: var(--paper);
  }
  .post-body figcaption {
    margin-top: 10px;
    color: var(--muted);
    font-size: 12px;
    text-align: left;
  }

  .post-body img {
    max-width: 100%;
    height: auto;
  }

  .post-body hr {
    border: none;
    border-top: 1px solid var(--line-soft);
    margin: 36px 0;
  }

  /* ─── Image lightbox ─── */
  .post-body img.zoomable {
    cursor: zoom-in;
    transition: opacity .2s var(--ease-out);
  }
  .post-body img.zoomable:hover { opacity: .9; }

  /* `hidden` attr must win over `.lightbox { display: flex }` below */
  .lightbox[hidden] { display: none !important; }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding: 40px 24px;
    /* Strong, theme-independent backdrop so the overlay always reads as a modal */
    background: rgba(8, 10, 14, 0.92);
    backdrop-filter: blur(8px) saturate(0.85);
    -webkit-backdrop-filter: blur(8px) saturate(0.85);
    opacity: 0;
    transition: opacity .2s var(--ease-out);
    cursor: zoom-out;
  }
  .lightbox.open { opacity: 1; }
  .lightbox-img {
    max-width: min(94vw, 1400px);
    max-height: 84vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: #fff;
    box-shadow: 0 24px 60px rgba(0, 0, 0, .55);
    transform: scale(.96);
    transition: transform .25s var(--ease-out);
  }
  .lightbox.open .lightbox-img { transform: scale(1); }
  .lightbox-cap {
    max-width: min(94vw, 1400px);
    color: rgba(255, 255, 255, 0.72);
    font-family: var(--font-mono);
    font-size: 12px;
    text-align: center;
  }
  .lightbox-close {
    position: absolute;
    top: 16px; right: 20px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: rgba(255, 255, 255, 0.92);
    width: 36px; height: 36px;
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    font-family: var(--font-mono);
    transition: background .2s var(--ease-out), border-color .2s var(--ease-out), color .2s var(--ease-out);
  }
  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: var(--accent);
    color: var(--accent);
  }
  @media (max-width: 480px) {
    .lightbox { padding: 24px 12px; }
    .lightbox-img { max-height: 78vh; }
  }
</style>
