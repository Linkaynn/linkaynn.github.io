---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

// Project + post data (mirrors the design's content.js)
const projects = [
  {
    id: "mymedesp",
    name: "Mymedesp",
    year: "2026 — now",
    tagline: {
      es: "App para gestionar recetario, lista de la compra y despensa.",
      en: "App to manage your recipe book, shopping list and pantry.",
    },
    stack: ["React", "TypeScript", "MobX", "styled-components", "NestJS", "Supabase"],
    url: "mymedesp.com",
  },
  {
    id: "characters-vault",
    name: "Characters Vault",
    year: "2026 — now",
    tagline: {
      es: "Gestor de fichas en la nube para rol de mesa.",
      en: "Cloud-based character sheet manager for tabletop RPGs.",
    },
    stack: ["TypeScript", "NestJS", "MobX", "React", "Node", "Docker", "Supabase"],
    url: "charactersvault.com",
  },
  {
    id: "animabf",
    name: "Anima Beyond Foundry",
    year: "2021 — now",
    tagline: {
      es: "Sistema open source para Foundry VTT — Anima Beyond Fantasy.",
      en: "Open-source game system for Foundry VTT — Anima Beyond Fantasy.",
    },
    stack: ["JavaScript", "TypeScript", "WebRTC", "P2P"],
    url: "foundryvtt.com/packages/animabf",
  },
  {
    id: "aristeia",
    name: "Aristeia App",
    year: "2020 — 2022",
    tagline: {
      es: "App para gestionar entrenamientos, usuarios y facturación de un club deportivo.",
      en: "App to manage training, users and billing for a sports club.",
    },
    stack: ["Android", "iOS", "Flutter", "GCP", "Firebase"],
    url: "aristeiaclub.com",
    archived: true,
  },
];

// Read blog posts from the content collection.
// Posts live as `src/content/blog/{slug}/{es,en}.md` — we pair them by slug.
const allEntries = await getCollection("blog");
const bySlug = new Map<string, { es?: typeof allEntries[number]; en?: typeof allEntries[number] }>();
for (const entry of allEntries) {
  const [postSlug, lang] = entry.id.replace(/\.(md|mdx)$/, "").split("/");
  const slot = bySlug.get(postSlug) ?? {};
  if (lang === "es") slot.es = entry;
  else if (lang === "en") slot.en = entry;
  bySlug.set(postSlug, slot);
}
const monthsEn = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
const showDrafts = import.meta.env.DEV;
const posts = [...bySlug.entries()]
  .filter(([, v]) => v.es && v.en)
  .filter(([, { es, en }]) => showDrafts || (!es!.data.draft && !en!.data.draft))
  .map(([postSlug, { es, en }]) => {
    const date = (en ?? es)!.data.date;
    return {
      slug: postSlug,
      date,
      dateLabel: `${monthsEn[date.getMonth()]} ${date.getDate()}, ${date.getFullYear()}`,
      title: { es: es!.data.title, en: en!.data.title },
    };
  })
  .sort((a, b) => b.date.getTime() - a.date.getTime());
---

<Layout
  title="Jesé Romero — Software Engineer"
  description="Software engineer based in Gran Canaria. Side projects, open source, tabletop RPG, piano and physics."
  keywords="software engineer, TypeScript, React, NestJS, Foundry VTT, Gran Canaria, Canary Islands"
  image="/home.png"
>
  <!-- ───────────────────── Hero ───────────────────── -->
  <section id="home" class="hero">
    <!-- Portrait: hover (desktop) / tap (mobile) crossfades between two photos. -->
    <div
      id="portrait"
      class="portrait"
      role="button"
      tabindex="0"
      aria-label="Jesé en el campo, con paisaje canario detrás. Pasa el ratón o toca para cambiar."
      data-alt-default="Jesé en el campo, con paisaje canario detrás"
      data-alt-fun="Jesé en el estadio de Las Palmas con colmillos de vampiro"
    >
      <div class="portrait-frame">
        <img class="portrait-img portrait-default" src="/assets/jese-serious.jpg" alt="" loading="eager" decoding="async" />
        <img class="portrait-img portrait-fun"     src="/assets/UD.JPG"          alt="" loading="eager" decoding="async" />
        <span class="portrait-scan" aria-hidden="true"></span>
        <span class="portrait-corner tl"></span>
        <span class="portrait-corner tr"></span>
        <span class="portrait-corner bl"></span>
        <span class="portrait-corner br"></span>
      </div>
      <div class="portrait-caption" aria-hidden="true">
        <span class="portrait-name">jese.jpg</span>
        <span class="portrait-hint" id="portrait-hint">hover ↻</span>
      </div>
    </div>

    <div class="hero-meta reveal" data-blur="0" data-y="6">
      <span class="hero-prompt">$</span>
      <span class="scramble" id="greeting" data-trigger="auto" data-text="—">—</span>
      <span class="dotsep">·</span>
      <span class="clock" id="live-clock">00:00:00</span>
      <span> · Gran Canaria, ES</span>
      <span class="visitor-clock" id="visitor-clock" hidden>
        <span class="dotsep">·</span>
        <span data-i18n-en="you" data-i18n-es="tú">you</span>
        <span class="dotsep">·</span>
        <span class="clock" id="visitor-time">00:00:00</span>
        <span> · </span>
        <span id="visitor-place"></span>
      </span>
    </div>

    <h1 class="hero-name">
      <span id="typed-name"></span><span class="dot" id="name-dot"></span><span class="caret-blink" id="name-caret">▌</span>
    </h1>

    <p class="hero-bio reveal" data-delay="850" data-blur="0" data-y="8">
      <span data-lang="en">
        Software engineer. You can find me sometimes developing a new
        <a href="/#projects" class="ulink magnetic project-inline" data-strength="0.3" data-smooth>
          <span class="scramble" data-text="idea">idea</span>
        </a>, and writing
        <a href="/#writing" class="ulink magnetic project-inline" data-strength="0.3" data-smooth>
          <span class="scramble" data-text="technical articles">technical articles</span>
        </a>
        (honestly, it's been a while). The rest of the time you'll find me hiking, running tabletop campaigns, learning a new piece on the piano or contributing to
        <a href="https://github.com/linkaynn" class="ulink magnetic project-inline" data-strength="0.3">
          <span class="scramble" data-text="open-source">open-source</span>
        </a>.
      </span>
      <span data-lang="es" hidden>
        Ingeniero de software. A veces me encontrarás desarrollando una nueva
        <a href="/#projects" class="ulink magnetic project-inline" data-strength="0.3" data-smooth>
          <span class="scramble" data-text="idea">idea</span>
        </a>, o escribiendo
        <a href="/#writing" class="ulink magnetic project-inline" data-strength="0.3" data-smooth>
          <span class="scramble" data-text="artículos técnicos">artículos técnicos</span>
        </a>
        (sinceramente, hace ya un tiempo). El resto del tiempo ando de senderismo, dirigiendo partidas de rol, aprendiendo una nueva pieza al piano o contribuyendo al
        <a href="https://github.com/linkaynn" class="ulink magnetic project-inline" data-strength="0.3">
          <span class="scramble" data-text="open source">open source</span>
        </a>.
      </span>
    </p>

    <div class="hero-socials reveal" data-delay="1170" data-blur="0" data-y="8">
      <a href="https://github.com/linkaynn" target="_blank" rel="noopener noreferrer" class="ulink magnetic" data-strength="0.4" data-radius="100">
        <span class="scramble" data-text="github">github</span> ↗
      </a>
      <a href="https://x.com/jeseromero" target="_blank" rel="noopener noreferrer" class="ulink magnetic" data-strength="0.4" data-radius="100">
        <span class="scramble" data-text="twitter">twitter</span> ↗
      </a>
      <a href="https://linkedin.com/in/jese-romero" target="_blank" rel="noopener noreferrer" class="ulink magnetic" data-strength="0.4" data-radius="100">
        <span class="scramble" data-text="linkedin">linkedin</span> ↗
      </a>
      <a href="https://instagram.com/jeseromeroarbelo" target="_blank" rel="noopener noreferrer" class="ulink magnetic" data-strength="0.4" data-radius="100">
        <span class="scramble" data-text="instagram">instagram</span> ↗
      </a>
    </div>
  </section>

  <!-- ───────────────────── Now ───────────────────── -->
  <section class="now">
    <h2 class="section-h reveal" data-blur="0" data-y="6">
      <span class="slashes">//</span>
      <span class="scramble" data-trigger="mount" data-text-en="now" data-text-es="ahora">now</span>
      <span class="now-live">
        <i class="now-pulse"></i>live
      </span>
    </h2>

    <dl class="now-grid">
      <dt class="reveal" data-delay="80"  data-blur="0" data-y="4" data-i18n-en="cooking"  data-i18n-es="cocinando">cooking</dt>
      <dd class="now-val reveal" data-delay="120" data-blur="0" data-y="4"
          data-en="with science"
          data-es="con ciencia">with science</dd>

      <dt class="reveal" data-delay="150" data-blur="0" data-y="4" data-i18n-en="studying" data-i18n-es="estudiando">studying</dt>
      <dd class="now-val reveal" data-delay="190" data-blur="0" data-y="4"
          data-en="physics — from first principles"
          data-es="física — desde primeros principios">physics — from first principles</dd>

      <dt class="reveal" data-delay="220" data-blur="0" data-y="4" data-i18n-en="at the piano" data-i18n-es="al piano">at the piano</dt>
      <dd class="now-val reveal" data-delay="260" data-blur="0" data-y="4"
          data-en="~7 years in, still slow"
          data-es="~7 años aporreándolo, sigo lento">~7 years in, still slow</dd>

      <dt class="reveal" data-delay="290" data-blur="0" data-y="4" data-i18n-en="GM-ing"   data-i18n-es="dirigiendo">GM-ing</dt>
      <dd class="now-val reveal" data-delay="330" data-blur="0" data-y="4"
          data-en="tabletop RPG campaigns"
          data-es="campañas de rol de mesa">tabletop RPG campaigns</dd>
    </dl>
  </section>

  <!-- ───────────────────── Projects ───────────────────── -->
  <section id="projects" class="projects">
    <h2 class="section-h reveal" data-blur="0" data-y="6">
      <span class="slashes">//</span>
      <span class="scramble" data-trigger="mount" data-text-en="projects" data-text-es="proyectos">projects</span>
    </h2>
    <ul class="proj-list">
      {projects.map((p, i) => {
        const inner = (
          <>
            <span class="proj-arrow">→</span>
            <div class="proj-head">
              <div>
                <span class="proj-name">{p.name}</span>
                <span class="proj-tag">— <span data-lang="en">{p.tagline.en}</span><span data-lang="es" hidden>{p.tagline.es}</span></span>
              </div>
              <span class="proj-year">
                {p.archived && (
                  <span class="proj-archived" data-i18n-en="archived" data-i18n-es="archivado">archived</span>
                )}
                {p.year.split(" — ")[0]}
              </span>
            </div>
            <div class="proj-stack">
              {p.stack.map((s, j) => (
                <span class="chip" style={`transition-delay: ${j * 30}ms`}>{s}</span>
              ))}
            </div>
          </>
        );
        return (
          <li class="reveal" data-delay={60 + i * 60} data-blur="0" data-y="6">
            {p.archived ? (
              <div class="proj-row archived">{inner}</div>
            ) : (
              <a class="proj-row" href={`https://${p.url}`} target="_blank" rel="noopener noreferrer">{inner}</a>
            )}
          </li>
        );
      })}
    </ul>
  </section>

  <!-- ───────────────────── Writing ───────────────────── -->
  <section id="writing" class="writing">
    <h2 class="section-h reveal" data-blur="0" data-y="6">
      <span class="slashes">//</span>
      <span class="scramble" data-trigger="mount" data-text-en="writing" data-text-es="escritos">writing</span>
    </h2>
    <ul class="post-list">
      {posts.map((p, i) => (
        <li class="reveal" data-delay={60 + i * 60} data-blur="0" data-y="6">
          <a class="post-row" href={`/blog/${p.slug}/`}>
            <span class="post-arrow">→</span>
            <span class="post-date">{p.dateLabel.split(",")[0]}</span>
            <span class="post-title">
              <span data-lang="en">{p.title.en}</span>
              <span data-lang="es" hidden>{p.title.es}</span>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- ───────────────────── Contact ───────────────────── -->
  <section id="contact" class="contact">
    <h2 class="section-h reveal" data-blur="0" data-y="6">
      <span class="slashes">//</span>
      <span class="scramble" data-trigger="mount" data-text-en="say hi" data-text-es="saluda">say hi</span>
    </h2>
    <p class="contact-text reveal" data-delay="80" data-blur="0" data-y="6">
      <span data-lang="en">Got a side project, an open-source itch to scratch, a one-shot to run, or want to climb Roque Nublo? </span>
      <span data-lang="es" hidden>¿Un side project, picor de open source que rascar, un one-shot que dirigir o subir al Roque Nublo? </span>
      <a href="https://linkedin.com/in/jese-romero" target="_blank" rel="noopener noreferrer" class="ulink magnetic contact-mail" data-strength="0.4" data-radius="140">
        <span class="scramble" data-text-en="Drop a line on LinkedIn" data-text-es="Escríbeme por LinkedIn">Drop a line on LinkedIn</span>
      </a>
    </p>
  </section>
</Layout>

<style>
  /* ─── Portrait (hero) ─── */
  .portrait {
    float: right;
    width: 130px; height: 130px;
    margin: 6px 0 26px 24px;
    position: relative;
    cursor: pointer;
    animation: fadeIn .8s var(--ease-out) .15s both;
    -webkit-tap-highlight-color: transparent;
  }
  .portrait:focus-visible { outline: 1px solid var(--accent); outline-offset: 4px; }
  .portrait-frame {
    position: absolute; inset: 0;
    border: 1px solid var(--line);
    background: var(--bg-elev);
    overflow: hidden;
    transition: transform .35s var(--ease-out);
  }
  .portrait.fun .portrait-frame { transform: rotate(-2deg) scale(1.02); }
  .portrait-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: opacity .35s var(--ease-out);
  }
  .portrait-default { object-position: 50% 18%; opacity: 1; filter: saturate(.85) contrast(1.05); }
  .portrait-fun     { object-position: 50% 28%; opacity: 0; }
  .portrait.fun .portrait-default { opacity: 0; }
  .portrait.fun .portrait-fun     { opacity: 1; }
  .portrait-scan {
    position: absolute; inset: 0; pointer-events: none;
    background: repeating-linear-gradient(0deg,
      rgba(0,0,0,0.06) 0px, rgba(0,0,0,0.06) 1px,
      transparent 1px, transparent 3px);
    mix-blend-mode: multiply;
  }
  .portrait-corner {
    position: absolute;
    width: 8px; height: 8px;
    border-color: var(--accent);
    border-style: solid;
    opacity: 0.9;
  }
  .portrait-corner.tl { top: 0;    left: 0;  border-width: 1px 0 0 1px; }
  .portrait-corner.tr { top: 0;    right: 0; border-width: 1px 1px 0 0; }
  .portrait-corner.bl { bottom: 0; left: 0;  border-width: 0 0 1px 1px; }
  .portrait-corner.br { bottom: 0; right: 0; border-width: 0 1px 1px 0; }
  .portrait-caption {
    position: absolute; left: 0; right: 0; bottom: -18px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: .1em;
    text-transform: uppercase;
    display: flex; justify-content: space-between;
    transition: color .2s var(--ease-out);
  }
  .portrait.fun .portrait-caption { color: var(--accent); }
  .portrait-hint {
    animation: breathe 2s var(--ease-out) infinite;
  }
  .portrait-hint.seen {
    animation: none;
    opacity: 0.4;
  }
  /* Avoid the portrait crashing into the bio at small widths */
  @media (max-width: 480px) {
    .portrait {
      width: 110px; height: 110px;
      margin-left: 16px;
    }
  }

  /* ─── Hero ─── */
  .hero {
    padding-bottom: 80px;
    scroll-margin-top: 80px;
  }
  .hero-meta {
    color: var(--muted);
    font-size: 13px;
    margin-bottom: 18px;
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
  }
  .hero-prompt { color: var(--accent); }
  .dotsep { color: var(--muted-2); }
  .clock { font-variant-numeric: tabular-nums; }

  .hero-name {
    font-family: var(--font-mono);
    font-size: 32px;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 14px;
    letter-spacing: -0.02em;
    line-height: 1.2;
    display: inline-flex;
    align-items: baseline;
  }
  .hero-name .dot {
    display: inline;
    color: var(--accent);
  }
  .hero-name .dot.show::before { content: "."; }
  .caret-blink {
    display: inline-block;
    margin-left: 2px;
    color: var(--accent);
    animation: blink 1.1s steps(2) infinite;
  }
  .caret-blink.done { color: var(--muted-2); }

  .hero-bio {
    margin: 0;
    color: var(--ink-2);
    font-size: 15px;
  }
  .hero-aside {
    margin: 14px 0 0;
    color: var(--muted);
    font-size: 15px;
  }
  .hero-socials {
    margin-top: 28px;
    display: flex;
    gap: 18px;
    font-size: 13px;
    flex-wrap: wrap;
  }

  .ulink {
    color: var(--muted);
    position: relative;
    display: inline-block;
  }
  .ulink::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: -2px;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform .45s var(--ease-out);
  }
  .ulink:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
  .project-inline { color: var(--ink); }
  .contact-mail   { color: var(--accent); }

  /* ─── Section H ─── */
  .section-h {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 18px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .section-h .slashes { color: var(--muted); }

  /* ─── Now ─── */
  .now {
    padding-bottom: 80px;
  }
  .now-live {
    margin-left: 6px;
    font-size: 11px;
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .now-pulse {
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 999px;
    animation: pulse 1.8s infinite;
  }
  .now-grid {
    margin: 0;
    display: grid;
    grid-template-columns: 150px 1fr;
    row-gap: 10px;
    column-gap: 16px;
  }
  .now-grid dt {
    color: var(--muted);
    font-size: 14px;
  }
  .now-grid dd {
    margin: 0;
    color: var(--ink);
    font-size: 14px;
    cursor: default;
  }

  /* ─── Projects ─── */
  .projects {
    padding-bottom: 80px;
    scroll-margin-top: 80px;
  }
  .proj-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .proj-row {
    display: block;
    padding: 12px 0;
    padding-left: 0;
    border-bottom: 1px solid var(--line-soft);
    position: relative;
    transition: padding-left .3s var(--ease-out);
  }
  .proj-row:hover { padding-left: 12px; }
  .proj-arrow {
    position: absolute;
    left: 0; top: 13px;
    color: var(--accent);
    font-size: 14px;
    opacity: 0;
    transform: translateX(-8px);
    transition: all .3s var(--ease-out);
  }
  .proj-row:hover .proj-arrow {
    opacity: 1;
    transform: translateX(0);
  }
  .proj-head {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 24px;
    align-items: baseline;
  }
  .proj-name {
    color: var(--ink);
    font-size: 15px;
  }
  .proj-tag {
    color: var(--muted);
    font-size: 14px;
    margin-left: 12px;
  }
  .proj-year {
    color: var(--muted-2);
    font-size: 13px;
    white-space: nowrap;
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
  }
  .proj-archived {
    color: var(--muted);
    font-size: 11px;
    padding: 1px 6px;
    border: 1px solid var(--line);
    letter-spacing: .05em;
  }

  /* Archived rows: no link affordance, still show stack on hover. */
  .proj-row.archived {
    cursor: default;
  }
  .proj-row.archived:hover { padding-left: 0; }
  .proj-row.archived .proj-arrow { display: none; }
  .proj-row.archived .proj-name { color: var(--muted); }
  .proj-row.archived .proj-tag  { color: var(--muted-2); }
  .proj-stack {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    max-height: 0;
    opacity: 0;
    margin-top: 0;
    overflow: hidden;
    transition:
      max-height .4s var(--ease-out),
      opacity .25s var(--ease-out),
      margin-top .3s var(--ease-out);
  }
  .proj-row:hover .proj-stack {
    max-height: 60px;
    opacity: 1;
    margin-top: 8px;
  }
  .proj-stack .chip {
    font-size: 11px;
    color: var(--muted);
    padding: 2px 7px;
    border: 1px solid var(--line);
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity .3s var(--ease-out),
      transform .3s var(--ease-out);
  }
  .proj-row:hover .proj-stack .chip {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── Writing ─── */
  .writing {
    padding-bottom: 80px;
    scroll-margin-top: 80px;
  }
  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .post-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 16px;
    padding: 12px 0;
    padding-left: 0;
    border-bottom: 1px solid var(--line-soft);
    align-items: baseline;
    transition: padding-left .3s var(--ease-out);
    position: relative;
  }
  .post-row:hover { padding-left: 12px; }
  .post-arrow {
    position: absolute;
