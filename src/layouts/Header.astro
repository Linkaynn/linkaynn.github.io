---
// Sticky minimal nav: breathing-dot logo, anchor links, ES/EN + ☀/☾ toggles.
---

<header class="site-header">
  <div class="hdr-inner">
    <a href="/#home" class="logo magnetic" data-strength="0.3">
      <button
        type="button"
        class="dot"
        id="logo-dot"
        aria-label="status"
      ></button>
      <span>jesé romero</span>
    </a>
    <nav>
      <a href="/#projects" class="ulink magnetic" data-strength="0.25" data-smooth>
        <span class="scramble" data-text-en="projects" data-text-es="proyectos">projects</span>
      </a>
      <a href="/#writing" class="ulink magnetic" data-strength="0.25" data-smooth>
        <span class="scramble" data-text-en="writing" data-text-es="escritos">writing</span>
      </a>
      <a href="/#contact" class="ulink magnetic" data-strength="0.25" data-smooth>
        <span class="scramble" data-text-en="contact" data-text-es="contacto">contact</span>
      </a>
      <span class="dotsep">·</span>
      <button class="mini magnetic" data-strength="0.25" id="lang-toggle" title="toggle language">
        <span data-i18n-en="en" data-i18n-es="es">en</span>
      </button>
      <button class="mini magnetic" data-strength="0.25" id="theme-toggle" aria-label="theme">
        <span id="theme-icon">☀</span>
      </button>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 5;
    background: color-mix(in oklab, var(--bg) 90%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line-soft);
  }
  .hdr-inner {
    max-width: 640px;
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 13px;
  }
  .logo {
    color: var(--ink);
    display: inline-flex;
    gap: 8px;
    align-items: center;
  }
  .dot {
    width: 8px;
    height: 8px;
    padding: 0;
    border: none;
    cursor: pointer;
    background: var(--accent);
    display: inline-block;
    animation: breathe 2.4s var(--ease-out) infinite;
    transform: scale(1);
    transition: transform .25s var(--ease-out), background .25s;
  }
  nav {
    display: flex;
    gap: 22px;
    align-items: center;
  }
  .ulink {
    color: var(--muted);
    font-size: 13px;
    position: relative;
    display: inline-block;
  }
  .ulink::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: -2px;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform .45s var(--ease-out);
  }
  .ulink:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }
  .ulink:hover { color: var(--ink); }
  .dotsep { color: var(--muted-2); }
  .mini {
    background: transparent;
    color: var(--muted);
    border: none;
    font-family: var(--font-mono);
    font-size: 13px;
    cursor: pointer;
    padding: 0;
  }
  .mini:hover { color: var(--ink); }

  /* ─── Mobile: drop the section anchors and tighten gaps ─── */
  @media (max-width: 600px) {
    .hdr-inner {
      padding: 12px 20px;
    }
    nav {
      gap: 14px;
    }
    nav > .ulink,
    nav > .dotsep {
      display: none;
    }
  }
</style>
