---
import { ViewTransitions } from "astro:transitions";
import "../styles/global.css";
import Header from "./Header.astro";
import Footer from "./Footer.astro";

interface Props {
  title: string;
  description: string;
  keywords?: string;
  image?: string;
}

const { title, description, keywords = "", image = "/home.png" } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light" data-lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Jesé Romero" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content="/" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ViewTransitions />

    <title>{title}</title>

    <script is:inline>
      // Prevent FOUC: apply theme & lang before paint.
      // Theme: explicit user choice in localStorage wins; otherwise follow the OS.
      (function () {
        try {
          const root = document.documentElement;
          const stored = localStorage.getItem("jr.theme");
          if (stored === "dark" || stored === "light") {
            root.dataset.theme = stored;
          } else if (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches) {
            root.dataset.theme = "dark";
          }
          const l = localStorage.getItem("jr.lang");
          if (l === "en" || l === "es") root.dataset.lang = l;
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <div id="spotlight" aria-hidden="true"></div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- CRT vintage overlay -->
    <div id="crt" aria-hidden="true" hidden>
      <div class="crt-scan"></div>
      <div class="crt-vignette"></div>
      <div class="crt-tint"></div>
      <div class="crt-badge">● rec · vintage mode</div>
    </div>

    <!-- Coffee easter egg container (filled by JS) -->
    <div id="coffee-host" aria-hidden="true"></div>

    <!-- Command palette overlay -->
    <div id="palette" hidden>
      <div class="palette-backdrop"></div>
      <div class="palette-window" role="dialog" aria-modal="true" aria-label="terminal">
        <div class="palette-head">
          <span>terminal · jese@portfolio</span>
          <span><kbd>esc</kbd></span>
        </div>
        <div class="palette-log" id="palette-log"></div>
        <form class="palette-form" id="palette-form" autocomplete="off">
          <span class="palette-prompt">$</span>
          <input
            id="palette-input"
            type="text"
            spellcheck="false"
            autocomplete="off"
            autocorrect="off"
            data-i18n-placeholder-en="type a command…"
            data-i18n-placeholder-es="escribe un comando…"
          />
          <span class="palette-caret">▌</span>
        </form>
      </div>
    </div>

    <!-- Hint chip — always visible -->
    <button id="hint-chip" type="button" aria-label="open terminal">
      <span class="hc-dollar">$</span>
      <kbd>/</kbd>
      <span data-i18n-en="open terminal" data-i18n-es="abrir terminal">open terminal</span>
    </button>

    <style is:global>
      main {
        max-width: 640px;
        margin: 0 auto;
        padding: 120px 32px 0;
        font-family: var(--font-mono);
        font-size: 15px;
        line-height: 1.7;
        color: var(--ink-2);
        position: relative;
        z-index: 1;
      }

      /* ─── Spotlight that follows the cursor ─── */
      #spotlight {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        opacity: 0;
        transition: opacity .4s var(--ease-out);
        background: radial-gradient(
          520px 520px at var(--mx, -1000px) var(--my, -1000px),
          var(--accent) 0%,
          transparent 70%
        );
      }
      html[data-theme="light"] #spotlight { mix-blend-mode: multiply; }
      html[data-theme="dark"]  #spotlight { mix-blend-mode: screen; }
      body.spotlight-on #spotlight { opacity: 0.08; }
      html[data-theme="dark"] body.spotlight-on #spotlight { opacity: 0.13; }

      /* ─── CRT vintage overlay ─── */
      #crt {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 50;
      }
      #crt[hidden] { display: none; }
      .crt-scan {
        position: absolute; inset: 0;
        background: repeating-linear-gradient(
          0deg,
          rgba(0,0,0,0.12) 0px,
          rgba(0,0,0,0.12) 1px,
          transparent 1px,
          transparent 3px
        );
        animation: scanShift 12s linear infinite;
        mix-blend-mode: multiply;
      }
      .crt-vignette {
        position: absolute; inset: 0;
        background: radial-gradient(circle at center, transparent 55%, rgba(0,0,0,0.35) 100%);
      }
      .crt-tint {
        position: absolute; inset: 0;
        background: color-mix(in oklab, oklch(0.85 0.2 145) 8%, transparent);
        mix-blend-mode: screen;
      }
      .crt-badge {
        position: absolute;
        top: 14px; right: 14px;
        font-family: var(--font-mono);
        font-size: 11px;
        color: oklch(0.85 0.2 145);
        border: 1px solid oklch(0.85 0.2 145);
        padding: 3px 8px;
        letter-spacing: .15em;
        text-transform: uppercase;
        animation: flicker 3s steps(2) infinite;
      }

      /* ─── Command palette ─── */
      #palette {
        position: fixed;
        inset: 0;
        z-index: 100;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        animation: fadeIn .2s var(--ease-out);
      }
      #palette[hidden] { display: none; }
      .palette-backdrop {
        position: absolute; inset: 0;
        background: color-mix(in oklab, var(--bg) 60%, transparent);
        backdrop-filter: blur(6px);
      }
      .palette-window {
        position: relative;
        width: min(720px, calc(100% - 32px));
        background: var(--paper);
        border: 1px solid var(--ink);
        box-shadow: 0 -8px 0 0 color-mix(in oklab, var(--accent) 30%, transparent);
        margin-bottom: 24px;
        font-family: var(--font-mono);
        animation: slideUp .25s var(--ease-out);
      }
      .palette-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 14px;
        border-bottom: 1px solid var(--line);
        font-size: 11px;
        color: var(--muted);
        letter-spacing: .1em;
        text-transform: uppercase;
      }
      .palette-log {
        padding: 14px 16px;
        max-height: 320px;
        overflow: auto;
        font-size: 13px;
        line-height: 1.55;
        color: var(--ink);
        white-space: pre-wrap;
      }
      .palette-log .row { margin-bottom: 2px; }
      .palette-log .row.cmd  { color: var(--accent); opacity: 1; }
      .palette-log .row.out  { color: var(--ink-2); opacity: .92; }
      .palette-log .row.err  { color: var(--accent-2); opacity: .92; }
      .palette-log .row.info { color: var(--muted); opacity: .92; }
      .palette-log .row.cmd::before { content: "$ "; color: var(--muted); }
      .palette-form {
        display: flex;
        align-items: center;
        gap: 8px;
        border-top: 1px solid var(--line);
        padding: 10px 14px;
        background: var(--bg-elev);
      }
      .palette-prompt {
        color: var(--accent);
        font-size: 13px;
      }
      .palette-form input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        font-family: var(--font-mono);
        font-size: 13px;
        color: var(--ink);
        padding: 4px;
      }
      .palette-caret {
        color: var(--accent);
        animation: blink 1.1s steps(2) infinite;
      }

      /* ─── kbd ─── */
      kbd {
        display: inline-block;
        padding: 1px 6px;
        border: 1px solid var(--line);
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--ink-2);
        margin: 0 2px;
        border-radius: 3px;
        background: var(--bg-elev);
      }

      /* ─── Hint chip ─── */
      #hint-chip {
        position: fixed;
        bottom: 18px; right: 18px;
        z-index: 40;
        background: var(--bg-elev);
        border: 1px solid var(--line);
        padding: 8px 12px;
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--muted);
        cursor: pointer;
        display: inline-flex;
        gap: 6px;
        align-items: center;
        animation: fadeIn 1.2s var(--ease-out) .8s both;
        transition: border-color .2s, color .2s;
      }
      #hint-chip:hover {
        border-color: var(--accent);
        color: var(--ink);
      }
      .hc-dollar { color: var(--accent); }

      /* ─── Coffee burst ─── */
      .coffee-burst {
        position: fixed;
        bottom: 60px;
        left: 50%;
        transform: translateX(-50%);
        font-family: var(--font-mono);
        font-size: 16px;
        line-height: 1.2;
        color: var(--accent);
        text-align: center;
        animation: coffeeRise 4s var(--ease-out) forwards;
        z-index: 60;
        pointer-events: none;
      }
      .coffee-burst pre {
        margin: 0;
        white-space: pre;
      }
      .coffee-brewed {
        margin-top: 4px;
        font-size: 11px;
        color: var(--muted);
      }
    </style>

    <script>
      import "../scripts/app";
    </script>
  </body>
</html>
