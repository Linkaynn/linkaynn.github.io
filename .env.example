# Contact form delivery (Resend) — required in production
# Sign up: https://resend.com  (free tier: 100 emails/day, 3 000/month)
# 1. Verify your domain in the Resend dashboard (DNS records on Vercel).
# 2. Create an API key with Sending Access.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# From address. Must use a domain you've verified in Resend. For quick
# testing you can keep "onboarding@resend.dev" (default if not set).
RESEND_FROM="Jesé Romero <hola@jeseromero.com>"
# Where contact messages land.
RESEND_TO=jeseromeroarbelo@gmail.com

# Rate limiting — optional in dev, required in production.
# Two ways to provision; both work, the code reads either set:
#
# A. Vercel Marketplace (recommended)
#    Vercel project → Storage → "Create" → pick Upstash Redis (or any
#    Redis integration). Vercel auto-injects KV_REST_API_URL +
#    KV_REST_API_TOKEN into the project's env.
#
# B. Direct Upstash (https://upstash.com)
#    Create a Redis database, then copy the REST URL + token here.
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=AY...your_token...
